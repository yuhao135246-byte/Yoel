generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductCategory {
  COFFEE
  OBJECT
  RESEARCH
}

enum OrderStatus {
  PENDING
  RESERVED
  PAID
  FULFILLED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  WECHAT_RESERVED
  PAID
  REFUNDED
}

enum DeliveryStatus {
  AVAILABLE
  FULL
  CLOSED
}

model Customer {
  id         String    @id @default(cuid())
  name       String
  phone      String    @unique
  wechatId   String?
  email      String?
  tags       String[]  @default([])
  note       String?
  totalSpend Decimal   @default(0) @db.Decimal(10, 2)
  orderCount Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  addresses  Address[]
  orders     Order[]
}

model Address {
  id          String   @id @default(cuid())
  customerId  String
  contactName String
  phone       String
  province    String?
  city        String
  district    String?
  line1       String
  line2       String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders      Order[]
}

model Product {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  category    ProductCategory
  series      String?
  description String
  price       Decimal         @db.Decimal(10, 2)
  unit        String
  imageUrl    String?
  tags        String[]        @default([])
  active      Boolean         @default(true)
  inventory   Int?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  orderItems  OrderItem[]
}

model DeliveryDate {
  id        String         @id @default(cuid())
  date      DateTime       @unique @db.Date
  window    String         @default("07:30 - 11:00")
  capacity  Int
  booked    Int            @default(0)
  status    DeliveryStatus @default(AVAILABLE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  orders    Order[]
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  customerId     String
  addressId      String?
  deliveryDateId String?
  status         OrderStatus   @default(PENDING)
  paymentStatus  PaymentStatus @default(UNPAID)
  subtotal       Decimal       @db.Decimal(10, 2)
  deliveryFee    Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  deliveryDate   DateTime?     @db.Date
  deliveryWindow String        @default("07:30 - 11:00")
  deliverySlot   String?
  deliveryNote   String?
  wechatPrepayId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  customer       Customer      @relation(fields: [customerId], references: [id])
  address        Address?      @relation(fields: [addressId], references: [id])
  deliveryDay    DeliveryDate? @relation(fields: [deliveryDateId], references: [id])
  items          OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
}
